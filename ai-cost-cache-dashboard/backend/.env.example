# ============================================================
# AI Cost & Cache Dashboard — backend .env.example
# Skopiuj jako .env:  cp .env.example .env
# ============================================================

# Demo mode: true = mock embeddings (no API key needed)
#            false = real sentence-transformers (downloads ~90MB model)
DEMO_MODE=true

# Port backendu (domyślnie 8001)
PORT=8001

# URL frontendu (dla CORS)
FRONTEND_URL=http://localhost:5173
