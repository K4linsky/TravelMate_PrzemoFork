# ============================================================
# TravelMate AI — .env.example
# Skopiuj ten plik jako .env i uzupełnij swoje klucze API:
#   cp .env.example .env
# ============================================================

# ── Model provider ───────────────────────────────────────────
# Wybierz jednego z: openai | anthropic | google | lmstudio
MODEL_PROVIDER=google
MODEL_TEMPERATURE=0.3

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Google Gemini ────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

# ── LM Studio (lokalny model) ────────────────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=your_local_model_name_here

# ── HERE Maps API (opcjonalne — geo enrichment) ──────────────
# Uzyskaj klucz na: https://developer.here.com/
HERE_API_KEY=your_here_api_key_here
HERE_BASE_URL=https://geocode.search.hereapi.com/v1
HERE_GEOCODE_BASE_URL=https://geocode.search.hereapi.com/v1
HERE_SEARCH_BASE_URL=https://discover.search.hereapi.com/v1

# ── TripAdvisor Content API (opcjonalne — zdjęcia i oceny) ───
# Uzyskaj klucz na: https://www.tripadvisor.com/developers
TRIPADVISOR_API_KEY=your_tripadvisor_api_key_here
TRIPADVISOR_BASE_URL=https://api.content.tripadvisor.com/api/v1
TRIPADVISOR_LANGUAGE=en
TRIPADVISOR_CURRENCY=USD
